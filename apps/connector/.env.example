PORT=3003
MAIN_API_URL="http://localhost:3001/api/v1"
CONNECTOR_KEY="dev-connector-key"
REDIS_HOST="localhost"
REDIS_PORT=6395

# Inbound webhook signature secrets (per aggregator). GATED: issued at each
# platform's POS/partner onboarding — set these in production. When unset, the
# connector falls back to a "dev-<platform>-secret" HMAC key for local testing.
ZOMATO_WEBHOOK_SECRET=
SWIGGY_WEBHOOK_SECRET=
URBANPIPER_WEBHOOK_SECRET=
# ONDC ed25519 signing public key (base64, raw 32-byte). GATED: normally resolved
# per-caller from the ONDC registry; set to force live ed25519 verification.
ONDC_SIGNING_PUBLIC_KEY=
