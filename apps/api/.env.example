DATABASE_URL="postgresql://stello:stello@localhost:5455/stello?schema=public"
# REQUIRED in production (NODE_ENV=production) — the app refuses to boot if unset.
JWT_SECRET="dev-secret-change-me"
PORT=3001
# REQUIRED in production — service-to-service key for the connector. App fails fast if unset.
CONNECTOR_KEY="dev-connector-key"
# Optional. Comma-separated allowed browser origins for CORS. If unset in
# production, defaults to https://kitchens.stellotechs.com. Dev reflects any origin.
# CORS_ORIGINS="https://kitchens.stellotechs.com,https://order.stellotechs.com"
