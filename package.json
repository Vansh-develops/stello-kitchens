{
  "name": "stello-kitchens",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "scripts": {
    "dev:api": "pnpm --filter @stello/api start:dev",
    "dev:pos": "pnpm --filter @stello/pos dev",
    "dev:kds": "pnpm --filter @stello/kds dev",
    "dev:dashboard": "pnpm --filter @stello/dashboard dev",
    "dev:connector": "pnpm --filter @stello/connector start:dev",
    "order": "pnpm --filter @stello/order dev",
    "edge:sidecar": "pnpm --filter @stello/edge sidecar",
    "edge:renderer": "pnpm --filter @stello/edge dev",
    "edge:electron": "pnpm --filter @stello/edge electron",
    "build": "pnpm -r build",
    "db:migrate": "pnpm --filter @stello/api prisma:migrate",
    "db:seed": "pnpm --filter @stello/api prisma:seed"
  }
}
